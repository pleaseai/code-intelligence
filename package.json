{
  "name": "code-please",
  "type": "module",
  "version": "0.1.11",
  "packageManager": "bun@1.3.5",
  "description": "Auto-format and type-check hooks for AI coding",
  "workspaces": [
    "packages/*",
    "apps/*",
    "hooks/scripts"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "start": "bun run packages/code/src/cli.ts",
    "dev": "turbo dev",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "build": "turbo build",
    "build:npm": "bun run scripts/generate-packages.ts",
    "publish:npm": "bun run build:npm && for dir in npm/code-*; do (cd \"$dir\" && bun publish --access public --tolerate-republish); done && cd npm/code && bun publish --access public --tolerate-republish",
    "prepare": "husky",
    "build:docs": "turbo run build --filter=@pleaseai/code-please-docs-site..."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-types": "^3.17.5",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.1",
    "@types/bun": "latest",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "turbo": "^2.6.3",
    "typescript": "^5.7.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": "eslint --fix"
  }
}
