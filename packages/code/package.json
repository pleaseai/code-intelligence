{
  "name": "@pleaseai/code",
  "type": "module",
  "version": "0.1.10",
  "description": "Auto-format and type-check hooks for AI coding",
  "author": "Minsu Lee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pleaseai/code"
  },
  "keywords": [
    "claude-code",
    "hooks",
    "formatter",
    "lsp",
    "ai-coding"
  ],
  "main": "src/index.ts",
  "files": [
    "hooks",
    "src"
  ],
  "scripts": {
    "dev": "bun --watch run src/cli.ts",
    "build": "echo 'Build handled by root build:npm'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test ./test"
  },
  "dependencies": {
    "@pleaseai/binaries": "workspace:*",
    "@pleaseai/code-format": "workspace:*",
    "@pleaseai/code-lsp": "workspace:*",
    "@pleaseai/logger": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
