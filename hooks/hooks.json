{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx @pleaseai/code format --stdin",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "npx @pleaseai/code lsp --stdin",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
