{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun $CLAUDE_PLUGIN_ROOT/hooks/scripts/code-runner.ts format --stdin || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
