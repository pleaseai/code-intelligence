{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $CLAUDE_PLUGIN_ROOT/hooks/scripts/ast-grep-context.ts",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun $CLAUDE_PLUGIN_ROOT/hooks/scripts/code-runner.ts format --stdin",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bun $CLAUDE_PLUGIN_ROOT/hooks/scripts/code-runner.ts lsp --stdin",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
