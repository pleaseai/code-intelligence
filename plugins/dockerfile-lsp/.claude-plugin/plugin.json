{
  "name": "dockerfile-lsp",
  "version": "0.1.19",
  "description": "Dockerfile Language Server for Claude Code",
  "repository": "https://github.com/chatbot-pf/code-please",
  "author": {
    "name": "PassionFactory"
  },
  "lspServers": {
    "dockerfile": {
      "command": "bunx",
      "args": ["@pleaseai/code@^0.1.0", "lsp-server", "dockerfile"],
      "extensionToLanguage": {
        ".dockerfile": "dockerfile"
      }
    }
  }
}
