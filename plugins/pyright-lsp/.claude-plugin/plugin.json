{
  "name": "pyright-lsp",
  "version": "0.1.19",
  "description": "Python (Pyright) Language Server for Claude Code",
  "repository": "https://github.com/chatbot-pf/code-please",
  "author": {
    "name": "PassionFactory"
  },
  "lspServers": {
    "pyright": {
      "command": "bunx",
      "args": ["@pleaseai/code@0.1.19", "lsp-server", "pyright"],
      "extensionToLanguage": {
        ".py": "python",
        ".pyi": "python"
      }
    }
  }
}
