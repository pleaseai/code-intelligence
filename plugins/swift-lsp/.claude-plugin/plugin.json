{
  "name": "swift-lsp",
  "version": "0.1.19",
  "description": "Swift (SourceKit) Language Server for Claude Code",
  "repository": "https://github.com/chatbot-pf/code-please",
  "author": {
    "name": "PassionFactory"
  },
  "lspServers": {
    "sourcekit": {
      "command": "bunx",
      "args": ["@pleaseai/code@^0.1.0", "lsp-server", "sourcekit"],
      "extensionToLanguage": {
        ".swift": "swift"
      }
    }
  }
}
