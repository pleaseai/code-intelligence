{
  "name": "ocaml-lsp",
  "version": "0.1.19",
  "description": "OCaml Language Server for Claude Code",
  "repository": "https://github.com/chatbot-pf/code-please",
  "author": {
    "name": "PassionFactory"
  },
  "lspServers": {
    "ocaml": {
      "command": "bunx",
      "args": ["@pleaseai/code@^0.1.0", "lsp-server", "ocaml"],
      "extensionToLanguage": {
        ".ml": "ocaml",
        ".mli": "ocaml"
      }
    }
  }
}
