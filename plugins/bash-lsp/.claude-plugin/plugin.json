{
  "name": "bash-lsp",
  "version": "0.1.19",
  "description": "Bash/Shell Language Server for Claude Code",
  "repository": "https://github.com/chatbot-pf/code-please",
  "author": {
    "name": "PassionFactory"
  },
  "lspServers": {
    "bash": {
      "command": "bunx",
      "args": ["@pleaseai/code@^0.1.0", "lsp-server", "bash"],
      "extensionToLanguage": {
        ".sh": "shellscript",
        ".bash": "shellscript",
        ".zsh": "shellscript",
        ".ksh": "shellscript"
      }
    }
  }
}
