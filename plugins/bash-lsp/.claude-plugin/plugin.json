{
  "name": "bash-lsp",
  "version": "0.1.19",
  "description": "Bash/Shell Language Server for Claude Code",
  "repository": "https://github.com/chatbot-pf/code-please",
  "author": {
    "name": "PassionFactory"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "diff -q \"${CLAUDE_PLUGIN_ROOT}/package.json\" \"${CLAUDE_PLUGIN_DATA}/package.json\" >/dev/null 2>&1 || (cd \"${CLAUDE_PLUGIN_DATA}\" && cp \"${CLAUDE_PLUGIN_ROOT}/package.json\" . && npm install --loglevel=error) || rm -f \"${CLAUDE_PLUGIN_DATA}/package.json\""
          }
        ]
      }
    ]
  },
  "lspServers": {
    "bash": {
      "command": "${CLAUDE_PLUGIN_DATA}/node_modules/.bin/bash-language-server",
      "args": ["start"],
      "extensionToLanguage": {
        ".sh": "shellscript",
        ".bash": "shellscript",
        ".zsh": "shellscript",
        ".ksh": "shellscript"
      }
    }
  }
}
