{
  "name": "code-intelligence-lsp",
  "version": "0.1.22",
  "description": "Unified multiplexing LSP — runs and merges multiple language servers per file (type-checker + linters), controlled via .please/config.yml. Works around Claude Code's one-server-per-extension limit.",
  "repository": "https://github.com/chatbot-pf/code-please",
  "author": {
    "name": "PassionFactory"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "diff -q \"${CLAUDE_PLUGIN_ROOT}/package.json\" \"${CLAUDE_PLUGIN_DATA}/package.json\" >/dev/null 2>&1 || (cd \"${CLAUDE_PLUGIN_DATA}\" && cp \"${CLAUDE_PLUGIN_ROOT}/package.json\" . && npm install --loglevel=error) || rm -f \"${CLAUDE_PLUGIN_DATA}/package.json\""
          }
        ]
      }
    ]
  },
  "lspServers": "./.lsp.json"
}
