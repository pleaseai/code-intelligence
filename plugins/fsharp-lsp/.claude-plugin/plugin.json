{
  "name": "fsharp-lsp",
  "version": "0.1.19",
  "description": "F# Language Server for Claude Code",
  "repository": "https://github.com/chatbot-pf/code-please",
  "author": {
    "name": "PassionFactory"
  },
  "lspServers": {
    "fsharp": {
      "command": "bunx",
      "args": ["@pleaseai/code@0.1.13", "lsp-server", "fsharp"],
      "extensionToLanguage": {
        ".fs": "fsharp",
        ".fsi": "fsharp",
        ".fsx": "fsharp",
        ".fsscript": "fsharp"
      }
    }
  }
}
