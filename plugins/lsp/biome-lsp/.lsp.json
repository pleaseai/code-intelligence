{
  "biome": {
    "command": "npx",
    "args": ["@biomejs/biome", "lsp-proxy", "--stdio"],
    "extensionToLanguage": {
      ".ts": "typescript",
      ".tsx": "typescriptreact",
      ".js": "javascript",
      ".jsx": "javascriptreact",
      ".mjs": "javascript",
      ".cjs": "javascript",
      ".mts": "typescript",
      ".cts": "typescript",
      ".json": "json",
      ".jsonc": "jsonc",
      ".css": "css",
      ".graphql": "graphql",
      ".gql": "graphql"
    }
  }
}
