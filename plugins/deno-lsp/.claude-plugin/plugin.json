{
  "name": "deno-lsp",
  "version": "0.1.22",
  "description": "Deno Language Server for Claude Code",
  "repository": "https://github.com/chatbot-pf/code-please",
  "author": {
    "name": "PassionFactory"
  },
  "lspServers": {
    "deno": {
      "command": "deno",
      "args": [
        "lsp"
      ],
      "extensionToLanguage": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact",
        ".mjs": "javascript"
      }
    }
  }
}
