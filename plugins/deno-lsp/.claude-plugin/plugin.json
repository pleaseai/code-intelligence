{
  "name": "deno-lsp",
  "version": "0.1.19",
  "description": "Deno Language Server for Claude Code",
  "repository": "https://github.com/chatbot-pf/code-please",
  "author": {
    "name": "PassionFactory"
  },
  "lspServers": {
    "deno": {
      "command": "bunx",
      "args": ["@pleaseai/code@0.1.13", "lsp-server", "deno"],
      "extensionToLanguage": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact",
        ".mjs": "javascript"
      }
    }
  }
}
